    "hash": "67fb513d0d1fa3e58b4e95dcf8d70e618f4e277474c0e88bc8d1a3e9d0730db1",
    "installer": {
        "script": "Start-Process -Wait $dir\\idman-install.exe -ArgumentList \"/DIR=$dir /NoIcons=1 /SILENT\"",
        "keep": true
    },
    "persist": ["IAS"],
    "post_install": [
        "Remove-Item $dir\\Installer.exe -Force",
        "$script = \"$bucketsdir\\$bucket\\scripts\\idm\\activate.ps1\"",
        "&target = \"$persist_dir\\IAS\"",
        "Copy-Item -Path -Destination $script $target -Force",
        "Set-Content -Path \"target\\activate.ps1\" -Value (Get-Content $script -Raw).Replace('$persist_dir', \"$persist_dir\\IAS\")"
    ],
    "checkver": {
        "url": "http://www.internetdownloadmanager.com/download.html",
        "regex": "idman([\\d]+)build([\\d]+)\\.exe",
        "replace": "${1}build${2}"
    },
    "uninstaller": {
        "file": "uninstall.exe"
    },
    "autoupdate": {
        "url": "https://mirror2.internetdownloadmanager.com/idman$match1build$match2.exe#/idman-install.exe"
    }
