{
    "version": "153.0b9",
    "description": "Developer builds of Firefox: the popular open source web browser.",
    "homepage": "https://www.mozilla.org/zh-CN/firefox/developer/",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://download-installer.cdn.mozilla.net/pub/devedition/releases/153.0b9/win64/zh-CN/Firefox%20Setup%20153.0b9.exe#/firefox-developer.7z",
            "hash": "sha512:be8a71e9ba47c29e8619178e6cd8a434acd7938cf393e281f8366f8f93b74503d96cab25416aac285398bf0a32882b6e57d948a5fe940740ac76b69d1d4979ec"
        },
        "32bit": {
            "url": "https://download-installer.cdn.mozilla.net/pub/devedition/releases/153.0b9/win32/zh-CN/Firefox%20Setup%20153.0b9.exe#/firefox-developer.7z",
            "hash": "sha512:aff5281393954e315248a779b849404835796cf9a77a2a3cf497fc12b1002f1c6d92daf960e9e4c1ae017757856bf7ac7ad3c043915662cf223e0a732e1d6b57"
        }
    },
    "extract_dir": "core",
    "bin": [
        [
            "firefox.exe",
            "firefox-dev"
        ]
    ],
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox Dev",
            "-P Scoop-Dev -no-remote"
        ],
        [
            "firefox.exe",
            "Firefox Dev Profile Manager",
            "-P"
        ]
    ],
    "persist": [
        "profile",
        "distribution"
    ],
    "post_install": [
        "firefox-dev -CreateProfile \"Scoop-Dev $persist_dir\\profile\"",
        "$appdata_dir = Join-Path $env:APPDATA \"\\Mozilla\\Firefox\\Profiles\\developer\"",
        "$persist_data_dir = Join-Path $persist_dir profile",
        "& \"$bucketsdir\\apps\\scripts\\link.ps1\" $appdata_dir $persist_data_dir",
        "$firefox_policies_json = Join-Path $persist_dir distribution firefox-policies.json",
        "Copy-Item $bucketsdir\\apps\\scripts\\firefox-policies.json $firefox_policies_json"
    ],
    "post_uninstall": [
        "$appdata_dir = Join-Path $env:APPDATA \"\\Mozilla\\Firefox\\Profiles\\developer\"",
        "& \"$bucketsdir\\apps\\scripts\\unlink.ps1\" $appdata_dir"
    ],
    "checkver": {
        "url": "https://aus5.mozilla.org/update/6/Firefox/93.0/_/WINNT_x86_64-msvc-x64/zh-CN/aurora/_/_/_/_/update.xml",
        "xpath": "/updates/update/patch/@URL",
        "regex": "devedition-([\\db.]+)-"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download-installer.cdn.mozilla.net/pub/devedition/releases/$version/win64/zh-CN/Firefox%20Setup%20$version.exe#/firefox-developer.7z",
                "hash": {
                    "url": "https://download-installer.cdn.mozilla.net/pub/devedition/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/zh-CN/$basename"
                }
            },
            "32bit": {
                "url": "https://download-installer.cdn.mozilla.net/pub/devedition/releases/$version/win32/zh-CN/Firefox%20Setup%20$version.exe#/firefox-developer.7z",
                "hash": {
                    "url": "https://download-installer.cdn.mozilla.net/pub/devedition/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/zh-CN/$basename"
                }
            }
        }
    },
    "notes": "To recover persisted profile, you need to open the Profile Manager with `firefox-developer -P` and create by selecting the portable profile directory."
}
