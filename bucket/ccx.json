  },
  "pre_install": [
    "Remove-Item \"$dir\\`$PLUGINSDIR\" -Force -Recurse"
  ],
  "post_install": [
    "$appdata_dir = Join-Path $env:APPDATA 'ccx-desktop'",
    "$persist_config_dir = Join-Path $persist_dir 'appdata'",
