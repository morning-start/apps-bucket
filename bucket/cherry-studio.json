        "home"
    ],
    "post_install": [
        "$data_dir = Join-Path $env:USERPROFILE \".cherrystudio\"",
        "$persist_home_dir = Join-Path $persist_dir home",
        "& \"$bucketsdir\\apps\\scripts\\link.ps1\" $data_dir $persist_home_dir",
        "$appdata_dir = Join-Path $env:APPDATA \"CherryStudio\"",
        "$persist_data_dir = Join-Path $persist_dir data",
        "& \"$bucketsdir\\apps\\scripts\\link.ps1\" $appdata_dir $persist_data_dir"
    ],
    "post_uninstall": [
        "$data_dir = Join-Path $env:USERPROFILE \".cherrystudio\"",
        "& \"$bucketsdir\\apps\\scripts\\unlink.ps1\" $data_dir",
        "$appdata_dir = Join-Path $env:APPDATA \"CherryStudio\"",
        "& \"$bucketsdir\\apps\\scripts\\unlink.ps1\" $appdata_dir"
    ],
    "checkver": {
        "github": "https://github.com/CherryHQ/cherry-studio"
    },
    "autoupdate": {
        "architecture": {
