        "& \"$bucketsdir\\apps\\scripts\\link.ps1\" $appdata_dir $persist_data_dir"
    ],
    "post_uninstall": [
        "$data_dir = Join-Path $env:USERPROFILE \".cherrystudio\"",
        "& \"$bucketsdir\\apps\\scripts\\unlink.ps1\" $data_dir",
        "$appdata_dir = Join-Path $env:APPDATA \"CherryStudio\"",
        "& \"$bucketsdir\\apps\\scripts\\unlink.ps1\" $appdata_dir"
