            "hash": "541b60bc4f36a35624af02f6efabba62c84a1d8d035660d7978df8d53434ecf6"
        },
        "arm64": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.9.1/Cherry-Studio-1.9.1-arm64-portable.exe#/cherry-studio.exe",
