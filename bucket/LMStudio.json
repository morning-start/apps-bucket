{
    "version": "0.4.6",
    "description": "Discover, download, and run local LLMs",
    "homepage": "https://lmstudio.ai/",
    "license": {
        "identifier": "Proprietary",
        "url": "https://lmstudio.ai/terms"
    },
    "architecture": {
        "64bit": {
            "url": "https://installers.lmstudio.ai/win32/x64/0.4.6-1/LM-Studio-0.4.6-1-x64.exe#/dl.7z",
            "installer": {
                "script": [
                    "Remove-Item \"$dir\\*\" -Exclude \"app-64.7z\"",
                    "Expand-7zipArchive \"$dir\\app-64.7z\" \"$dir\"",
                    "Remove-Item \"$dir\\app-64.7z\""
                ]
            }
        },
        "arm64": {
            "url": "https://installers.lmstudio.ai/win32/arm64/0.4.6-1/LM-Studio-0.4.6-1-arm64.exe#/dl.7z",
            "installer": {
                "script": [
                    "Remove-Item \"$dir\\*\" -Exclude \"app-arm64.7z\"",
                    "Expand-7zipArchive \"$dir\\app-arm64.7z\" \"$dir\"",
                    "Remove-Item \"$dir\\app-arm64.7z\""
                ]
            }
        }
    },
    "post_install": [
        "$originPath = Join-Path $env:USERPROFILE \".cache\\lm-studio\"",
        "$targetPath = Join-Path $persist_dir \"lm-studio\"",
        "& \"$bucketsdir\\$bucket\\scripts\\link.ps1\" $originPath $targetPath",
        "$originPath = Join-Path $env:APPDATA \"LM Studio\"",
        "$targetPath = Join-Path $persist_dir \"appdata\"",
        "& \"$bucketsdir\\$bucket\\scripts\\link.ps1\" $originPath $targetPath"
    ],
    "post_uninstall": [
        "$originPath = Join-Path $env:USERPROFILE \".cache\\lm-studio\"",
        "$targetPath = Join-Path $persist_dir \"lm-studio\"",
        "& \"$bucketsdir\\$bucket\\scripts\\unlink.ps1\" $originPath $targetPath",
        "$originPath = Join-Path $env:APPDATA \"LM Studio\"",
        "$targetPath = Join-Path $persist_dir \"appdata\"",
        "& \"$bucketsdir\\$bucket\\scripts\\unlink.ps1\" $originPath $targetPath"
    ],
    "persist": [
        "lm-studio",
        "appdata"
    ],
    "extract_dir": "$PLUGINSDIR",
    "bin": "resources\\app\\.webpack\\lms.exe",
    "shortcuts": [
        [
            "LM Studio.exe",
            "LM Studio"
        ]
    ],
    "checkver": {
        "regex": "\\\\\"title\\\\\"\\s*:\\s*\\\\\"Windows\\\\\"\\s*,\\s*\\\\\"subtitle\\\\\"\\s*:\\s*\\\\\"([\\d.]+)\\\\\""
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://installers.lmstudio.ai/win32/x64/$version-1/LM-Studio-$version-1-x64.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://installers.lmstudio.ai/win32/arm64/$version-1/LM-Studio-$version-1-arm64.exe#/dl.7z"
            }
        }
    }
}
